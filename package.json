{
  "name": "retry-model-request",
  "version": "1.0.0",
  "description": "对 coding plan、token plan 的反向代理，在供应商接口报错时自动重试，避免客户端由于报错而中断执行任务。",
  "main": "src/main.ts",
  "type": "module",
  "scripts": {
    "start": "node --env-file=.env src/main.ts",
    "dev": "node --env-file=.env --watch src/main.ts",
    "lint": "prettier --write . && eslint . --fix && tsc --noEmit"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/bulls-cows/retry-model-request.git"
  },
  "keywords": [],
  "author": "",
  "license": "Apache-2.0",
  "bugs": {
    "url": "https://github.com/bulls-cows/retry-model-request/issues"
  },
  "homepage": "https://github.com/bulls-cows/retry-model-request#readme",
  "imports": {
    "#scripts/*.ts": "./src/scripts/*.ts"
  },
  "dependencies": {
    "axios": "^1.15.2",
    "express": "^5.2.1",
    "http-proxy-middleware": "^3.0.5"
  },
  "devDependencies": {
    "@eslint/js": "10.0.1",
    "@types/eslint__js": "9.14.0",
    "@types/express": "^5.0.6",
    "@types/node": "^25.6.0",
    "eslint": "10.2.1",
    "prettier": "3.8.3",
    "typescript": "^6.0.3",
    "typescript-eslint": "8.59.0"
  }
}
